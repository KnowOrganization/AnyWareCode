# Discord application (https://discord.com/developers/applications)
DISCORD_TOKEN=
DISCORD_CLIENT_ID=

# GitHub App (https://github.com/settings/apps/new) — see README for permissions
GITHUB_APP_ID=
GITHUB_APP_SLUG=anywherecode
# PEM contents; literal \n is fine
GITHUB_APP_PRIVATE_KEY=

# Platform Anthropic key (v1: no BYO keys)
ANTHROPIC_API_KEY=

DATABASE_URL=postgres://anywherecode:anywherecode@localhost:5432/anywherecode

# Public base URL GitHub redirects to after app install (dev: cloudflared/ngrok)
PUBLIC_URL=https://example.com
# Random >=16 chars; signs the install state linking guild <-> installation
STATE_SECRET=

HTTP_PORT=3000
RUNNER_IMAGE=anywherecode-runner
# Production: RUNNER_NETWORK=anywherecode-egress and the proxy below.
# Dev: leave RUNNER_NETWORK empty for default bridge networking.
RUNNER_NETWORK=
RUNNER_HTTPS_PROXY=http://egress-proxy:8888

DEFAULT_TASK_CAP=50
TASK_TIMEOUT_MINUTES=30
