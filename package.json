{
  "name": "anywarecode",
  "private": true,
  "version": "0.1.0",
  "description": "Discord bot that runs a shared coding agent against your GitHub repos and opens PRs",
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "dev": "pnpm --filter @anywarecode/bot dev"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "overrides": {
      "@types/node": "22.19.21"
    }
  }
}
