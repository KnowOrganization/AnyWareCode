{
	"name": "@anywarecode/bot",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"scripts": {
		"build": "tsc -p tsconfig.json",
		"typecheck": "tsc -p tsconfig.json --noEmit",
		"test": "vitest run",
		"dev": "dotenv -e ../../.env -- tsx watch src/index.ts",
		"start": "node dist/index.js",
		"register-commands": "dotenv -e ../../.env -- tsx src/discord/register.ts"
	},
	"dependencies": {
		"@anywarecode/db": "workspace:*",
		"@anywarecode/shared": "workspace:*",
		"@discordjs/voice": "^0.19.2",
		"@sentry/node": "^10.57.0",
		"discord.js": "^14.16.0",
		"dockerode": "^4.0.0",
		"drizzle-orm": "^0.44.0",
		"fastify": "^5.0.0",
		"libsodium-wrappers": "^0.8.4",
		"octokit": "^4.0.0",
		"opusscript": "^0.1.1",
		"pino": "^10.3.1",
		"prism-media": "^1.3.5",
		"zod": "^3.25.0"
	},
	"devDependencies": {
		"@types/dockerode": "^3.3.0",
		"dotenv-cli": "^11.0.0",
		"fast-check": "^3.23.0",
		"tsx": "^4.19.0",
		"typescript": "^5.6.0",
		"vitest": "^3.0.0"
	}
}
